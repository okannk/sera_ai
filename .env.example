# SERA AI — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyala, değerleri doldur.
# .env asla git'e commit edilmez!

# ── MQTT ──────────────────────────────────────────────────────
SERA_MQTT_HOST=localhost
SERA_MQTT_PORT=1883
MQTT_KULLANICI=
MQTT_SIFRE=

# ── Telegram Bildirimi ────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890
TWILIO_TO=+905001234567

# ── E-Posta ───────────────────────────────────────────────────
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# ── REST API ──────────────────────────────────────────────────
SERA_API_KEY=degistir-beni-guclu-bir-anahtar-koy
